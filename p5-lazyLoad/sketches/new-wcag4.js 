const CANVAS_WIDTH = 1920;
const CANVAS_HEIGHT = 1080;

const CELL_SIZE = 72;
const GRID_GAP = 8;
const STUD_DIAMETER = 34;
const PRESS_EASE = 0.14;

let bricks = [];
let basePlateStuds = [];
let backgroundColor;
let plateColor;
let brickPalette;

function setup() {
  createCanvas(1920, 1080);
  pixelDensity(1);
  rectMode(CORNER);
  ellipseMode(CENTER);
  noStroke();

  randomSeed(42);
  noiseSeed(42);

  backgroundColor = color("#090b08");
  plateColor = color("#151a13");

  brickPalette = [
    color("#263d2a"),
    color("#314f35"),
    color("#4b3a24"),
    color("#5b4527"),
    color("#6a5a2d"),
    color("#7b6b35"),
    color("#8a7a42"),
    color("#3c4930"),
    color("#2f3324")
  ];

  createBasePlateStuds();
  createBrickComposition();
}

function draw() {
  background(backgroundColor);

  drawAtmosphericBackground();
  drawBasePlate();
  updateBricks();

  for (let i = 0; i < bricks.length; i++) {
    drawBrickShadow(bricks[i]);
  }

  for (let i = 0; i < bricks.length; i++) {
    drawBrick(bricks[i]);
  }

  drawSoftVignette();
}

function createBrickComposition() {
  bricks = [];

  const cols = floor((width - 140) / CELL_SIZE);
  const rows = floor((height - 140) / CELL_SIZE);
  const offsetX = (width - cols * CELL_SIZE) * 0.5;
  const offsetY = (height - rows * CELL_SIZE) * 0.5;
  const occupied = createOccupiedGrid(cols, rows);

  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {
      if (occupied[y][x]) continue;

      const distanceFromCenter = dist(x, y, cols * 0.5, rows * 0.5);
      const placementChance = map(distanceFromCenter, 0, max(cols, rows) * 0.6, 0.95, 0.42);

      if (random() > placementChance) continue;

      let size = chooseBrickSize(x, y, cols, rows, occupied);

      if (!size) continue;

      markOccupiedCells(occupied, x, y, size.studsWide, size.studsHigh);

      const brickX = offsetX + x * CELL_SIZE + GRID_GAP;
      const brickY = offsetY + y * CELL_SIZE + GRID_GAP;
      const brickW = size.studsWide * CELL_SIZE - GRID_GAP * 1.6;
      const brickH = size.studsHigh * CELL_SIZE - GRID_GAP * 1.6;
      const patternType = floor(random(5));

      bricks.push({
        x: brickX,
        y: brickY,
        w: brickW,
        h: brickH,
        studsWide: size.studsWide,
        studsHigh: size.studsHigh,
        studs: createStudLayout(size.studsWide, size.studsHigh),
        color: random(brickPalette),
        patternType: patternType,
        cornerRadius: random([5, 6, 8, 10]),
        baseOffsetZ: random(13, 20),
        pressedOffsetZ: random(2, 5),
        currentOffsetZ: random(13, 20),
        heightShade: random(0.88, 1.1),
        seed: random(10000),
        hovered: false
      });
    }
  }

  bricks.sort(function (a, b) {
    return a.y + a.h - (b.y + b.h);
  });
}

function createOccupiedGrid(cols, rows) {
  const occupied = [];

  for (let y = 0; y < rows; y++) {
    occupied[y] = [];
    for (let x = 0; x < cols; x++) {
      occupied[y][x] = false;
    }
  }

  return occupied;
}

function chooseBrickSize(x, y, cols, rows, occupied) {
  const candidates = [
    { studsWide: 1, studsHigh: 1 },
    { studsWide: 2, studsHigh: 1 },
    { studsWide: 1, studsHigh: 2 },
    { studsWide: 2, studsHigh: 2 },
    { studsWide: 3, studsHigh: 1 },
    { studsWide: 1, studsHigh: 3 },
    { studsWide: 4, studsHigh: 1 },
    { studsWide: 2, studsHigh: 3 }
  ];

  shuffle(candidates, true);

  for (let i = 0; i < candidates.length; i++) {
    const size = candidates[i];

    if (canPlaceBrick(occupied, x, y, size.studsWide, size.studsHigh, cols, rows)) {
      return size;
    }
  }

  return null;
}

function canPlaceBrick(occupied, x, y, studsWide, studsHigh, cols, rows) {
  if (x + studsWide > cols || y + studsHigh > rows) return false;

  for (let yy = 0; yy < studsHigh; yy++) {
    for (let xx = 0; xx < studsWide; xx++) {
      if (occupied[y + yy][x + xx]) return false;
    }
  }

  return true;
}

function markOccupiedCells(occupied, x, y, studsWide, studsHigh) {
  for (let yy = 0; yy < studsHigh; yy++) {
    for (let xx = 0; xx < studsWide; xx++) {
      occupied[y + yy][x + xx] = true;
    }
  }
}

function createStudLayout(studsWide, studsHigh) {
  const studs = [];

  for (let sy = 0; sy < studsHigh; sy++) {
    for (let sx = 0; sx < studsWide; sx++) {
      studs.push({
        x: (sx + 0.5) * CELL_SIZE,
        y: (sy + 0.5) * CELL_SIZE
      });
    }
  }

  return studs;
}

function createBasePlateStuds() {
  basePlateStuds = [];

  const spacing = 54;
  const margin = 42;

  for (let y = margin; y < height - margin; y += spacing) {
    for (let x = margin; x < width - margin; x += spacing) {
      if (random() < 0.72) {
        basePlateStuds.push({
          x: x + random(-5, 5),
          y: y + random(-5, 5),
          size: random(10, 15),
          alpha: random(16, 34)
        });
      }
    }
  }
}

function drawAtmosphericBackground() {
  noStroke();

  for (let y = 0; y < height; y += 6) {
    const n = noise(y * 0.006);
    const shade = lerpColor(color("#070907"), color("#11170f"), n);
    fill(red(shade), green(shade), blue(shade), 180);
    rect(0, y, width, 6);
  }

  for (let i = 0; i < 520; i++) {
    const x = random(width);
    const y = random(height);
    const alpha = random(4, 16);
    fill(180, 170, 130, alpha);
    rect(x, y, random(1, 3), random(1, 3));
  }
}

function drawBasePlate() {
  const plateMargin = 52;

  noStroke();
  fill(0, 0, 0, 105);
  rect(plateMargin + 18, plateMargin + 24, width - plateMargin * 2, height - plateMargin * 2, 18);

  fill(plateColor);
  rect(plateMargin, plateMargin, width - plateMargin * 2, height - plateMargin * 2, 18);

  stroke(255, 255, 255, 16);
  strokeWeight(1);
  noFill();
  rect(plateMargin + 1, plateMargin + 1, width - plateMargin * 2 - 2, height - plateMargin * 2 - 2, 18);

  noStroke();

  for (let i = 0; i < basePlateStuds.length; i++) {
    const stud = basePlateStuds[i];

    fill(0, 0, 0, stud.alpha);
    ellipse(stud.x + 2, stud.y + 3, stud.size * 1.2, stud.size);

    fill(70, 82, 58, stud.alpha);
    ellipse(stud.x, stud.y, stud.size, stud.size);
  }
}

function updateBricks() {
  for (let i = 0; i < bricks.length; i++) {
    const brick = bricks[i];

    brick.hovered =
      mouseX >= brick.x &&
      mouseX <= brick.x + brick.w &&
      mouseY >= brick.y &&
      mouseY <= brick.y + brick.h;

    const targetOffset = brick.hovered ? brick.pressedOffsetZ : brick.baseOffsetZ;
    brick.currentOffsetZ = lerp(brick.currentOffsetZ, targetOffset, PRESS_EASE);
  }
}

function drawBrickShadow(brick) {
  const z = brick.currentOffsetZ;
  const shadowStrength = map(z, brick.pressedOffsetZ, brick.baseOffsetZ, 90, 155);

  noStroke();
  fill(0, 0, 0, shadowStrength);
  rect(brick.x + z * 0.7 + 7, brick.y + z * 0.9 + 12, brick.w, brick.h, brick.cornerRadius);
}

function drawBrick(brick) {
  const z = brick.currentOffsetZ;
  const topX = brick.x + (brick.baseOffsetZ - z) * 0.45;
  const topY = brick.y + (brick.baseOffsetZ - z) * 0.45;

  const bodyColor = brick.hovered
    ? lerpColor(brick.color, color("#050605"), 0.16)
    : brick.color;

  const topColor = adjustColorValue(bodyColor, 1.08 * brick.heightShade);
  const sideColor = adjustColorValue(bodyColor, 0.68);
  const lowerSideColor = adjustColorValue(bodyColor, 0.5);
  const highlightColor = lerpColor(topColor, color(230, 225, 190), 0.18);
  const outlineColor = color(5, 7, 5, 210);

  noStroke();

  fill(lowerSideColor);
  rect(brick.x, brick.y + z, brick.w, brick.h, brick.cornerRadius);

  fill(sideColor);
  rect(brick.x, brick.y + z, brick.w, brick.h * 0.8, brick.cornerRadius);

  drawSideRidge(brick, z, lowerSideColor);

  stroke(outlineColor);
  strokeWeight(2);
  fill(topColor);
  rect(topX, topY, brick.w, brick.h, brick.cornerRadius);

  noStroke();
  fill(255, 255, 255, 24);
  rect(topX + 5, topY + 5, brick.w - 10, 5, 3);

  fill(0, 0, 0, 42);
  rect(topX + 5, topY + brick.h - 9, brick.w - 10, 4, 3);

  drawBrickPattern(brick, topX, topY);
  drawBrickStuds(brick, topX, topY, topColor, highlightColor, lowerSideColor);

  if (brick.hovered) {
    drawPressedCue(brick, topX, topY);
  }
}

function drawSideRidge(brick, z, ridgeColor) {
  fill(0, 0, 0, 35);

  if (brick.studsWide > brick.studsHigh) {
    for (let i = 1; i < brick.studsWide; i++) {
      const x = brick.x + i * CELL_SIZE - GRID_GAP * 0.7;
      rect(x, brick.y + z + brick.h * 0.68, 3, brick.h * 0.22, 2);
    }
  } else {
    for (let i = 1; i < brick.studsHigh; i++) {
      const y = brick.y + z + i * CELL_SIZE - GRID_GAP * 0.7;
      rect(brick.x + brick.w * 0.08, y, brick.w * 0.18, 3, 2);
    }
  }

  fill(ridgeColor);
}

function drawBrickPattern(brick, topX, topY) {
  push();

  const patternAlpha = brick.hovered ? 62 : 48;
  stroke(12, 15, 10, patternAlpha);
  strokeWeight(2);
  noFill();

  drawingContext.save();
  drawingContext.beginPath();
  drawingContext.rect(topX + 3, topY + 3, brick.w - 6, brick.h - 6);
  drawingContext.clip();

  if (brick.patternType === 0) {
    drawDiagonalHatching(topX, topY, brick.w, brick.h, 18, false);
  } else if (brick.patternType === 1) {
    drawDiagonalHatching(topX, topY, brick.w, brick.h, 20, true);
  } else if (brick.patternType === 2) {
    drawHorizontalBands(topX, topY, brick.w, brick.h);
  } else if (brick.patternType === 3) {
    drawDottedTexture(topX, topY, brick.w, brick.h, brick.seed);
  } else {
    drawCornerNotches(topX, topY, brick.w, brick.h);
  }

  drawingContext.restore();
  pop();
}

function drawDiagonalHatching(x, y, w, h, spacing, reverseDirection) {
  for (let i = -h; i < w + h; i += spacing) {
    if (reverseDirection) {
      line(x + i, y, x + i - h, y + h);
    } else {
      line(x + i, y + h, x + i + h, y);
    }
  }
}

function drawHorizontalBands(x, y, w, h) {
  for (let yy = y + 16; yy < y + h; yy += 22) {
    line(x + 10, yy, x + w - 10, yy);
  }
}

function drawDottedTexture(x, y, w, h, seed) {
  noStroke();
  fill(10, 12, 8, 46);

  for (let i = 0; i < 34; i++) {
    const px = x + noise(seed + i * 0.7) * w;
    const py = y + noise(seed + 100 + i * 0.7) * h;
    ellipse(px, py, 3, 3);
  }
}

function drawCornerNotches(x, y, w, h) {
  stroke(12, 15, 10, 58);
  strokeWeight(3);

  const notch = 14;
  line(x + 9, y + 9, x + 9 + notch, y + 9);
  line(x + 9, y + 9, x + 9, y + 9 + notch);

  line(x + w - 9, y + h - 9, x + w - 9 - notch, y + h - 9);
  line(x + w - 9, y + h - 9, x + w - 9, y + h - 9 - notch);
}

function drawBrickStuds(brick, topX, topY, topColor, highlightColor, shadowColor) {
  for (let i = 0; i < brick.studs.length; i++) {
    const stud = brick.studs[i];
    const sx = topX + stud.x - GRID_GAP * 0.8;
    const sy = topY + stud.y - GRID_GAP * 0.8;
    const studColor = brick.hovered ? adjustColorValue(topColor, 0.88) : adjustColorValue(topColor, 1.03);

    noStroke();

    fill(0, 0, 0, 105);
    ellipse(sx + 4, sy + 5, STUD_DIAMETER * 1.04, STUD_DIAMETER * 0.9);

    fill(shadowColor);
    ellipse(sx, sy + 3, STUD_DIAMETER, STUD_DIAMETER);

    stroke(5, 7, 5, 180);
    strokeWeight(2);
    fill(studColor);
    ellipse(sx, sy, STUD_DIAMETER, STUD_DIAMETER);

    noStroke();
    fill(highlightColor);
    ellipse(sx - 6, sy - 7, STUD_DIAMETER * 0.36, STUD_DIAMETER * 0.18);

    fill(255, 255, 255, brick.hovered ? 14 : 26);
    ellipse(sx - 2, sy - 3, STUD_DIAMETER * 0.58, STUD_DIAMETER * 0.36);
  }
}

function drawPressedCue(brick, topX, topY) {
  noFill();
  stroke(235, 220, 160, 58);
  strokeWeight(2);
  rect(topX + 4, topY + 4, brick.w - 8, brick.h - 8, brick.cornerRadius);

  stroke(0, 0, 0, 80);
  strokeWeight(1);
  rect(topX + 9, topY + 9, brick.w - 18, brick.h - 18, max(2, brick.cornerRadius - 3));
}

function drawSoftVignette() {
  noFill();

  for (let i = 0; i < 95; i++) {
    const alpha = map(i, 0, 94, 0, 9);
    stroke(0, 0, 0, alpha);
    strokeWeight(12);
    rect(i * 5, i * 3, width - i * 10, height - i * 6);
  }
}

function adjustColorValue(sourceColor, amount) {
  return color(
    constrain(red(sourceColor) * amount, 0, 255),
    constrain(green(sourceColor) * amount, 0, 255),
    constrain(blue(sourceColor) * amount, 0, 255),
    alpha(sourceColor)
  );
}